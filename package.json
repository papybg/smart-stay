{
  "name": "smart-stay",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:dashboard-css": "tailwindcss -c tailwind.dashboard.config.cjs -i styles/dashboard.tailwind.input.css -o public/dashboard.tailwind.css --minify",
    "build:index-css": "tailwindcss -c tailwind.index.config.cjs -i styles/dashboard.tailwind.input.css -o public/index.tailwind.css --minify",
    "build:css": "npm run build:dashboard-css && npm run build:index-css"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@neondatabase/serverless": "^0.10.4",
    "@tuya/tuya-connector-nodejs": "^2.1.2",
    "axios": "^1.13.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "googleapis": "^144.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
